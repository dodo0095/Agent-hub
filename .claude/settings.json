{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"/c/Program Files/nodejs/node\" .claude/hooks/forbidden-commands.js"
          },
          {
            "type": "command",
            "command": "\"/c/Program Files/nodejs/node\" .claude/hooks/g5-pre-deploy.js"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/c/Program Files/nodejs/node\" .claude/hooks/g1-design-check.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/c/Program Files/nodejs/node\" .claude/hooks/g4-knowledge-check.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/c/Program Files/nodejs/node\" .claude/hooks/stop-validator.js",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
