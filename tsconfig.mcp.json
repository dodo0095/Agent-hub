{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "out/mcp",
    "rootDir": "electron/mcp",
    "types": ["node"]
  },
  "include": ["electron/mcp/send-message-server.ts"]
}
